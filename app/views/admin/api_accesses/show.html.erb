<div class="w-full p-4 flex-col justify-start items-start gap-4 inline-flex">
  <div class="self-stretch bg-white rounded-md border border-gray-200 flex-col justify-start items-start flex">
    <div class="self-stretch p-6 border-b border-gray-200 justify-start items-center gap-4 inline-flex">
      <div class="grow shrink basis-0 text-gray-900 text-xl font-semibold leading-[35px]">API Prístup</div>
    </div>
    <div class="self-stretch p-6 flex-col justify-start items-start gap-6 inline-flex">
      <div class="self-stretch flex-col justify-start items-start gap-2 inline-flex">
        <div class="text-gray-500 text-sm font-medium leading-tight">ID tenanta</div>
        <div class="text-gray-900 text-base font-mono leading-normal"><%= Current.tenant.id %></div>
      </div>
      <div class="self-stretch flex-col justify-start items-start gap-2 inline-flex">
        <div class="text-gray-500 text-sm font-medium leading-tight">Verejný kľúč pre API tokeny</div>
        <div class="text-gray-500 text-xs leading-tight max-w-xl">
          Vložte 2048-bitový RSA verejný kľúč (PEM formát), ktorý sa použije na overovanie API tokenov.
        </div>
      </div>
      <%= form_with model: Current.tenant, url: admin_tenant_api_access_path(Current.tenant), method: :patch, class: "w-full max-w-2xl" do |form| %>
        <div class="flex flex-col gap-4">
          <div>
            <%= form.label :api_token_public_key, "Verejný kľúč", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_area :api_token_public_key, 
                value: Current.tenant.api_token_public_key,
                rows: 8, 
                placeholder: "-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----",
                class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm #{'border-red-500' if Current.tenant.errors[:api_token_public_key].any?}" %>
            <% if Current.tenant.errors[:api_token_public_key].any? %>
              <p class="mt-1 text-sm text-red-600"><%= Current.tenant.errors[:api_token_public_key].first %></p>
            <% end %>
          </div>
          <div class="flex items-center gap-4">
            <%= form.button type: "submit", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium text-sm" do %>
              Uložiť
            <% end %>
            <% if Current.tenant.api_token_public_key.present? %>
              <%= button_to "Odstrániť kľúč", 
                  { action: :update },
                  method: :patch,
                  form: { data: { turbo_submits_with: "Odstraňujem..." } },
                  params: { tenant: { api_token_public_key: "" } },
                  form_class: "inline",
                  class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300 font-medium text-sm",
                  data: { turbo_confirm: "Naozaj chcete odstrániť verejný kľúč? Bez neho nebude možné overovať API tokeny." } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
