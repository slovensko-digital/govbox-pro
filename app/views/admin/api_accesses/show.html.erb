<div class="w-full p-4 flex-col justify-start items-start gap-4 inline-flex">

  <div class="self-stretch bg-white rounded-md border border-gray-200 p-6 flex justify-between items-center">
    <div class="text-gray-900 text-lg font-semibold">
      ID tenanta
    </div>
    <div class="text-gray-900 text-base font-mono bg-gray-50 px-3 py-1.5 rounded border border-gray-200">
      <%= Current.tenant.id %>
    </div>
  </div>

  <div class="self-stretch bg-white rounded-md border border-gray-200 flex-col justify-start items-start flex">
    <div class="self-stretch p-6 border-b border-gray-200 justify-start items-center gap-4 inline-flex">
      <div class="grow shrink basis-0 text-gray-900 text-xl font-semibold leading-[35px]">
        Verejný kľúč pre overovanie API tokenov
      </div>
    </div>

    <div class="self-stretch p-6 flex-col justify-start items-start gap-6 inline-flex w-full">
      <div class="text-gray-500 text-sm leading-tight max-w-3xl">
        Vložte 2048-bitový RSA verejný kľúč v PEM formáte, ktorý sa použije na asymetrické overovanie API tokenov.
      </div>

      <%= form_with model: Current.tenant, url: admin_tenant_api_access_path(Current.tenant), method: :patch, class: "w-full max-w-3xl" do |form| %>
        <div class="flex flex-col gap-4">
          <div>
            <%= form.text_area :api_token_public_key,
                               rows: 8,
                               placeholder: "-----BEGIN PUBLIC KEY-----\nMIICIjANBgkqhkiG9w0BAQEFAAOCAg8AMIICCgKCAgEA...\n-----END PUBLIC KEY-----",
                               class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm focus:ring-blue-600 focus:border-blue-600 #{'border-red-500 ring-red-500 focus:ring-red-500 focus:border-red-500' if Current.tenant.errors[:api_token_public_key].any?}" %>
            <% if Current.tenant.errors[:api_token_public_key].any? %>
              <p class="mt-1 text-sm font-medium text-red-600"><%= Current.tenant.errors[:api_token_public_key].first %></p>
            <% end %>
          </div>

          <div class="flex items-center gap-4 mt-2">
            <%= form.button "Uložiť", type: "submit", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium text-sm transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

</div>