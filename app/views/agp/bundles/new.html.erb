<%= tag.turbo_frame id: "modal" do %>
  <%= render Common::ModalComponent.new(closable: true) do |modal| %>
    <% modal.with_header do %>
      Podpisovanie
    <% end %>
    <% modal.with_modal_content do %>
      <div class="py-4">
        <div class="flex items-start gap-4">
          <svg class="mt-0.5 h-6 w-6 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>

          <div>
            <p class="text-base font-semibold text-gray-900">
              Pripravujeme podpisovanie cez Autogram Portal.
            </p>
            <p class="mt-1 text-sm text-gray-600">
              Môže to trvať niekoľko sekúnd. Ak sa príprava nepodarí, automaticky spustíme podpisovanie cez Autogram.
            </p>
          </div>
        </div>

        <%= form_with model: @bundle, url: agp_bundles_path, method: :post, data: { turbo_frame: "modal" }, html: { id: "agp-bundle-autostart-form", class: "hidden" } do |f| %>
          <%= f.hidden_field :bundle_identifier %>
          <% @bundle.contracts.each_with_index do |contract, index| %>
            <%= f.fields_for :contracts, contract do |cf| %>
              <%= cf.hidden_field :contract_identifier %>
              <%= cf.hidden_field :message_object_id %>
              <%= cf.hidden_field :message_object_updated_at %>
            <% end %>
          <% end %>

          <%= hidden_field_tag :message_draft_id, params[:message_draft_id] if params[:message_draft_id].present? %>
          <% Array(params[:message_thread_ids]).each do |id| %>
            <%= hidden_field_tag "message_thread_ids[]", id %>
          <% end %>
          <% Array(params[:object_ids]).each do |id| %>
            <%= hidden_field_tag "object_ids[]", id %>
          <% end %>
        <% end %>

        <script>
          (() => {
            const form = document.getElementById("agp-bundle-autostart-form")
            if (!form || form.dataset.submitted === "true") return

            form.dataset.submitted = "true"
            requestAnimationFrame(() => form.requestSubmit())
          })()
        </script>
      <% end %>
    </div>
  <% end %>
<% end %>
