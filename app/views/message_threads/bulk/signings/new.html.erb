<%= tag.turbo_frame id: "modal" do %>
  <%= render Common::ModalComponent.new(max_size: "max-w-lg md:max-w-xl") do |modal| %>
    <% modal.with_header do %>
      Hromadné podpisovanie
    <% end %>
    <% modal.with_modal_content do %>
      <%= form_with url: start_message_threads_bulk_signing_path, method: :post, data: { turbo_frame: "modal" } do %>

        <% @message_thread_ids.each do |id| %>
          <%= hidden_field_tag "message_thread_ids[]", id %>
        <% end %>

        <div class="w-full my-4">
          <p class="pb-2">Vybrané vlákna obsahujú <%= t("signing.documents", count: @message_objects.length) %> na podpis.</p>
          <% if Current.tenant.agp_signing_enabled? %>
            <p class="text-sm text-gray-600">
              V prípade problémov s novým podpisovaním použite
              <%= button_tag "starší spôsob", type: :submit, class: "inline p-0 text-sm font-medium text-blue-700 underline underline-offset-2 hover:text-blue-800 hover:no-underline" %>.
            </p>
          <% end %>
        </div>

        <%= render Common::ModalActionsComponent.new do |actions| %>
          <% actions.with_submit_button do %>
            <% if Current.tenant.agp_signing_enabled? %>
              <%= link_to "Podpísať", new_agp_bundle_path(message_thread_ids: @message_thread_ids), data: { turbo_frame: "modal" }, class: "inline-flex w-full justify-center items-center px-3 py-2 rounded-md font-medium text-left text-sm text-white bg-blue-700 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 focus:outline-none dark:focus:ring-blue-800 hover:cursor-pointer sm:w-auto" %>
            <% else %>
              <%= submit_tag "Podpísať Autogramom", class: "inline-flex w-full justify-center items-center px-3 py-2 rounded-md font-medium text-left text-sm text-white bg-blue-700 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 focus:outline-none dark:focus:ring-blue-800 hover:cursor-pointer sm:w-auto" %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
