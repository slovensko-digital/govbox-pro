<div class="flex justify-between gap-4 px-4 md:px-6 py-4 bg-white border-t-0 border-r-0 border-b border-l-0 border-gray-200" data-test="header">
  <div class="flex flex-col grow md:flex-row justify-start relative gap-4">
    <div class="flex flex-col flex-wrap gap-2 md:gap-4">
      <div class="flex gap-2">
        <span class="text-xl [word-break:break-word] font-semibold text-left text-gray-900" data-test="title" data-controller="text-wrap">
          <%= @message_thread.title %>
        </span>
      </div>
      <div class="flex flex-wrap items-center gap-1" data-test="tags" data-controller="content-with-separator">
        <div class="flex gap-4 mr-3" data-content-with-separator-target="separator-container">
          <%= render Common::BoxLabelComponent.new(@message_thread.box, "", "text-xs sm:text-sm", "px-2 py-0.5") %>
          <div class="h-6 sm:h-8 w-px bg-gray-900/10" aria-hidden="true" data-content-with-separator-target="separator"></div>
        </div>
        <% @thread_tags.each do |thread_tag| %>
          <%= render Common::TagComponent.new(thread_tag.tag) %>
        <% end %>
        <%= link_to edit_message_thread_tags_path(@message_thread), data: { turbo_frame: "modal" }, title: "Upraviť štítky", class: "rounded-md bg-blue-100 p-[5px] hover:bg-blue-200" do %>
          <%= render Icons::TagComponent.new(css_classes: "h-4 w-4 text-blue-600", stroke_width: 2) %>
        <% end %>
      </div>

      <div data-controller="scroll"
           data-scroll-top-threshold-value="300"
           data-scroll-bottom-show-threshold-value="320"
           data-scroll-bottom-hide-threshold-value="180"
           class="fixed bottom-8 right-8 z-[100] pointer-events-none flex flex-col gap-3">

        <button data-scroll-target="topButton"
                data-action="click->scroll#scrollToTop"
                type="button"
                title="Hore"
                class="opacity-0 scale-95 translate-y-0 pointer-events-none
                 data-[visible]:opacity-100 data-[visible]:scale-100 data-[visible]:pointer-events-auto
                 data-[bottom-hidden]:translate-y-14
                 transform-gpu transition-all duration-300 ease-out flex items-center justify-center w-11 h-11 rounded-full bg-white text-gray-500 shadow-md ring-1 ring-inset ring-gray-300 hover:bg-gray-50 hover:text-gray-900 focus:outline-none cursor-pointer">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
          </svg>
        </button>

        <button data-scroll-target="bottomButton"
                data-action="click->scroll#scrollToBottom"
                type="button"
                title="Dole"
                class="opacity-0 scale-95 pointer-events-none
                 data-[visible]:opacity-100 data-[visible]:scale-100 data-[visible]:pointer-events-auto
                 transform-gpu transition-all duration-300 ease-out flex items-center justify-center w-11 h-11 rounded-full bg-white text-gray-500 shadow-md ring-1 ring-inset ring-gray-300 hover:bg-gray-50 hover:text-gray-900 focus:outline-none cursor-pointer">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  <%= render MessageThreadOptionsComponent.new(@message_thread) %>
</div>